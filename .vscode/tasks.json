{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Smart Expense App",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": ["app.py"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": ["$python"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Start the Flask application using the workspace virtual environment."
    }
  ]
}
